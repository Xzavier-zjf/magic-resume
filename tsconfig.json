{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "src/app/**/layout.tsx",
    "src/app/app/page.tsx",
    "src/app/api/**/*.ts",
    "src/app/layout.tsx",
    "src/app/manifest.ts",
    "src/app/sitemap.ts",
    "src/components/Document.tsx",
    "src/components/shared/UpdateLocale.tsx",
    "src/i18n/db.ts",
    "src/i18n/request.ts",
    "src/middleware.ts"
  ]
}
